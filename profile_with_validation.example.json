          "banned_phrases": [],
          "required_patterns": ["launched", "drove", "delivered"]
        }
      }
    },
    
    "global_rules": {
      "max_summary_lines": 4,
      "selected_impact_metrics": 5,
      "role_compression": {
        "enabled": true,
        "older_than_years": 10,
